{
  "name": "bp-cap-fiori",
  "version": "1.0.0",
  "description": "Business Partner CAP Application with Fiori Elements UI",
  "engines": { "node": ">=20" },
  "scripts": {
    "start":   "cds-serve",
    "predev":  "test -f db/dev.sqlite || npx cds deploy",
    "dev":     "cds watch",
    "build":   "cds build --production",
    "deploy":  "mbt build -p cf && cf deploy mta_archives/bp-cap-fiori_1.0.0.mtar --retries 1",
    "lint":    "eslint srv/"
  },
  "dependencies": {
    "@sap/cds":          "^9.0.0",
    "@sap/cds-fiori":    "^2.3.0",
    "@sap/xssec":        "^4.9.1",
    "passport":          "^0.7.0",
    "hdb":               "^0.19.0",
    "@sap/hana-client":  "^2.19.0",
    "express":           "^5.0.0",
    "@gavdi/cap-mcp":    "^1.7.0"
  },
  "devDependencies": {
    "@sap/ux-specification":    "~1.120.0",
    "@sap/cds-dk":              "^9.0.0",
    "@cap-js/sqlite":           "^2.4.0",
    "eslint":                   "^10.0.0"
  },
  "cds": {
    "requires": {
      "[development]": {
        "db": {
          "kind": "sqlite",
          "credentials": { "url": "db/dev.sqlite" }
        },
        "auth": {
          "kind": "mocked",
          "users": {
            "viewer@test.com":    { "roles": ["BP_VIEWER"] },
            "processor@test.com": { "roles": ["BP_PROCESSOR"] },
            "admin@test.com":     { "roles": ["BP_ADMIN"] }
          }
        }
      },
      "[production]": {
        "db":   { "kind": "hana-cloud" },
        "auth": { "kind": "xsuaa" }
      }
    },
    "hana":  { "deploy-format": "hdbtable" },
    "i18n":  { "default_language": "en" },
    "log":   { "levels": { "sql": "debug" } },
    "server": { "shutdown-timeout": 15000 },
    "mcp": {
      "name": "bp-manager-mcp",
      "auth": "inherit",
      "instructions": "MCP server for the Business Partner Manager. Exposes Business Partners (persons, organisations, groups) as a queryable resource, plus tools to block/unblock a Business Partner and get aggregate summary counts. Access is governed by the same role-based access control as the OData service: BP_VIEWER (read), BP_PROCESSOR (read + write + block), BP_ADMIN (full access including unblock)."
    }
  }
}
